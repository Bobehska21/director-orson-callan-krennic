{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-work-fetch.sh\"",
            "statusMessage": "Checking upstream before work"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-commit-push.sh\"",
            "statusMessage": "Committing, validating, rebasing, and pushing"
          }
        ]
      }
    ]
  }
}
