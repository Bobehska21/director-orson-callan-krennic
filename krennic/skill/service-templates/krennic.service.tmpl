[Unit]
Description=Krennic — lokální AI code-review agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=__BIN__ run
Restart=on-failure
RestartSec=5
# Least privilege: runs as the invoking user (systemd --user).
# Ensure ~/.local/bin (claude CLI) is on PATH — systemd --user má jinak minimální PATH.
Environment="PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

[Install]
WantedBy=default.target
